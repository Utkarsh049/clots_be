{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "dist",

    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,

    "types": ["node"],

    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"]
}